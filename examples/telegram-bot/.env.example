# Tavily (optional) — get from https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Admin Telegram user ID (optional, for /admin commands)
# ADMIN_USER_ID=123456789

# MCP Albert (optional) — remote MCP server via SSE
# MCP_ALBERT_URL=https://mcp.oialbert.com.br/mcp
# MCP_ALBERT_TOKEN=your-token-here
