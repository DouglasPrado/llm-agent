{
  "name": "agentx-sdk",
  "version": "0.5.4",
  "description": "AgentX SDK - Standalone TypeScript agent library with streaming, tools, memory, knowledge (RAG), and skills",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "docs:dev": "cd documentation && npx mintlify@latest dev",
    "docs:build": "cd documentation && npx mintlify@latest build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DouglasPrado/agentx-sdk.git"
  },
  "homepage": "https://github.com/DouglasPrado/agentx-sdk#readme",
  "bugs": {
    "url": "https://github.com/DouglasPrado/agentx-sdk/issues"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.14",
      "postcss": ">=8.5.10",
      "vite": ">=6.4.2"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "license": "MIT"
}
